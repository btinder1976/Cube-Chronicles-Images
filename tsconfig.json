{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types", "astro/client"],
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["src/lib/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@content/*": ["src/content/*"]
    },
    "strictNullChecks": true
  },
  "include": ["src", "tests", "scripts", ".astro/types.d.ts"],
  "exclude": ["dist", "node_modules"]
}
