---
export interface Crumb { label: string; href?: string; }
export interface Props { items: Crumb[]; }
const { items } = Astro.props;
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {items.map((c, i) => (
      <li>
        {c.href && i < items.length - 1 ? (
          <a href={c.href}>{c.label}</a>
        ) : (
          <span aria-current="page">{c.label}</span>
        )}
        {i < items.length - 1 && <span class="sep" aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs ol { list-style: none; display: flex; flex-wrap: wrap; gap: 0.35rem; padding: 0; margin: 0; font-family: var(--font-sans); font-size: 0.85rem; }
  .breadcrumbs a { color: var(--link); text-decoration: none; }
  .breadcrumbs a:hover { text-decoration: underline; }
  .breadcrumbs [aria-current='page'] { color: var(--muted); }
  .breadcrumbs .sep { color: var(--parchment-dark); margin-left: 0.35rem; }
</style>
