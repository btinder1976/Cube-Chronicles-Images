---
import { getBook } from '../lib/content';
export interface Props { prevSlug: string | null; nextSlug: string | null; }
const { prevSlug, nextSlug } = Astro.props;
const prev = prevSlug ? getBook(prevSlug) : undefined;
const next = nextSlug ? getBook(nextSlug) : undefined;
---
<nav class="prevnext" aria-label="Reading order">
  <div class="pn-cell pn-prev">
    {prev ? (
      <a href={prev.url}>
        <span class="pn-label">← Previous</span>
        <span class="pn-title">Book {prev.number}: {prev.title}</span>
      </a>
    ) : <span class="pn-empty">This is Book One</span>}
  </div>
  <div class="pn-cell pn-series"><a href="/books">All 15 books</a></div>
  <div class="pn-cell pn-next">
    {next ? (
      <a href={next.url}>
        <span class="pn-label">Next →</span>
        <span class="pn-title">Book {next.number}: {next.title}</span>
      </a>
    ) : <span class="pn-empty">This is the finale</span>}
  </div>
</nav>

<style>
  .prevnext { display: grid; grid-template-columns: 1fr auto 1fr; gap: 1rem; align-items: center; margin: 2rem 0; }
  .pn-cell a { display: flex; flex-direction: column; text-decoration: none; color: var(--indigo-800); font-family: var(--font-sans); }
  .pn-next a { text-align: right; }
  .pn-label { font-size: 0.78rem; color: var(--gold-600); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
  .pn-title { font-size: 0.95rem; }
  .pn-cell a:hover .pn-title { text-decoration: underline; }
  .pn-series a { font-size: 0.85rem; font-family: var(--font-sans); color: var(--muted); text-decoration: none; }
  .pn-empty { font-family: var(--font-sans); font-size: 0.82rem; color: var(--muted); }
  @media (max-width: 640px) { .prevnext { grid-template-columns: 1fr; text-align: left; } .pn-next a { text-align: left; } .pn-series { order: 3; } }
</style>
