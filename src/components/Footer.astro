---
import { books } from '../lib/content';
const year = 2026;
const featured = books.slice(0, 5);
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="footer-brand"><strong>The Cube Chronicles</strong></p>
      <p class="muted-light">A 15-book historical time-travel adventure for young readers and families, by Jeremy Tinder.</p>
    </div>
    <nav aria-label="Books">
      <h2>The Books</h2>
      <ul>
        {featured.map((b) => (<li><a href={b.url}>Book {b.number} — {b.title}</a></li>))}
        <li><a href="/books"><em>See all 15 books →</em></a></li>
      </ul>
    </nav>
    <nav aria-label="Explore">
      <h2>Explore</h2>
      <ul>
        <li><a href="/faq">Series FAQ</a></li>
        <li><a href="/series-facts">Series facts</a></li>
        <li><a href="/about">About the series</a></li>
        <li><a href="/ask">Ask a question</a></li>
        <li><a href="/rss.xml">Updates (RSS)</a></li>
      </ul>
    </nav>
    <nav aria-label="Legal">
      <h2>Legal & Contact</h2>
      <ul>
        <li><a href="/privacy">Privacy Policy</a></li>
        <li><a href="/terms">Terms of Use</a></li>
        <li><a href="/community-guidelines">Community Guidelines</a></li>
        <li><a href="/cookies">Cookie & Analytics Notice</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
  </div>
  <div class="container footer-base">
    <p>© {year} Jeremy Tinder. The Cube Chronicles and all book titles are works of fiction.</p>
    <p><a href="/">cubechronicles.com</a></p>
  </div>
</footer>

<style>
  .site-footer { background: var(--indigo-900); color: var(--parchment); margin-top: 4rem; padding-block: 3rem 1.5rem; border-top: 3px solid var(--gold-600); }
  .footer-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: 2rem; }
  .site-footer h2 { color: var(--gold-300); font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.1em; font-family: var(--font-sans); margin: 0 0 0.75rem; }
  .site-footer ul { list-style: none; margin: 0; padding: 0; }
  .site-footer li { margin-bottom: 0.4rem; }
  .site-footer a { color: var(--parchment); text-decoration: none; font-family: var(--font-sans); font-size: 0.9rem; }
  .site-footer a:hover { color: var(--gold-300); text-decoration: underline; }
  .footer-brand strong { font-family: var(--font-serif); font-size: 1.15rem; color: var(--cream); }
  .muted-light { color: #b9ad91; font-size: 0.9rem; }
  .footer-base { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; padding-top: 1.25rem; border-top: 1px solid rgba(255,255,255,0.12); font-family: var(--font-sans); font-size: 0.82rem; color: #b9ad91; }
  .footer-base a { color: var(--gold-300); }
  @media (max-width: 820px) { .footer-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .footer-grid { grid-template-columns: 1fr; } }
</style>
