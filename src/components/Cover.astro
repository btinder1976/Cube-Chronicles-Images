---
/**
 * Responsive front-only book cover.
 *
 * The production covers are committed directly under /public/covers as:
 *   book-01.jpg ... book-15.jpg
 *
 * Keep this component intentionally simple for the first Cloudflare deployment.
 * Optimized AVIF/WebP derivatives can be added later without risking broken
 * srcset selections when generated files are absent.
 */
export interface Props {
  book: { number: number; coverAlt: string };
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'auto';
  class?: string;
}

const {
  book,
  sizes = '(max-width: 600px) 45vw, 220px',
  loading = 'lazy',
  fetchpriority = 'auto',
  class: className = '',
} = Astro.props;

const n = String(book.number).padStart(2, '0');
const src = `/covers/book-${n}.jpg`;
const displayW = 480;
const displayH = Math.round((displayW * 2560) / 1600);
---

<picture class={`cover ${className}`}>
  <img
    src={src}
    sizes={sizes}
    width={displayW}
    height={displayH}
    alt={book.coverAlt}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
  />
</picture>

<style>
  .cover { display: block; }
  .cover img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px;
    box-shadow: 0 10px 26px -12px rgba(16, 24, 46, 0.55);
    background: linear-gradient(135deg, var(--indigo-700), var(--indigo-900));
    aspect-ratio: 1600 / 2560;
    object-fit: cover;
  }
</style>
