---
/**
 * Responsive book cover. Optimized derivatives are generated by
 * scripts/optimize-images.mjs into /covers/generated/ as:
 *   book-XX-{320,480,640,960}.{avif,webp,jpg}
 * Falls back to the single /covers/book-XX.jpg if derivatives are absent.
 * Front-only ebook covers are 1600×2560 (5:8 aspect).
 */
export interface Props {
  book: { number: number; coverAlt: string };
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'auto';
  widths?: number[];
  class?: string;
}
const {
  book,
  sizes = '(max-width: 600px) 45vw, 220px',
  loading = 'lazy',
  fetchpriority = 'auto',
  widths = [320, 480, 640, 960],
  class: className = '',
} = Astro.props;

const n = String(book.number).padStart(2, '0');
const base = `/covers/generated/book-${n}`;
const fallback = `/covers/book-${n}.jpg`;
const srcset = (ext: string) => widths.map((w) => `${base}-${w}.${ext} ${w}w`).join(', ');
const displayW = 480;
const displayH = Math.round((displayW * 2560) / 1600);
---
<picture class={`cover ${className}`}>
  <source type="image/avif" srcset={srcset('avif')} sizes={sizes} />
  <source type="image/webp" srcset={srcset('webp')} sizes={sizes} />
  <img
    src={fallback}
    srcset={srcset('jpg')}
    sizes={sizes}
    width={displayW}
    height={displayH}
    alt={book.coverAlt}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
  />
</picture>

<style>
  .cover { display: block; }
  .cover img {
    width: 100%; height: auto; display: block;
    border-radius: 8px;
    box-shadow: 0 10px 26px -12px rgba(16,24,46,0.55);
    background: linear-gradient(135deg, var(--indigo-700), var(--indigo-900));
    aspect-ratio: 1600 / 2560;
    object-fit: cover;
  }
</style>
