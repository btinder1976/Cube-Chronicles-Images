---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Turnstile from '../components/Turnstile.astro';
import Flash from '../components/Flash.astro';
import { csrfFieldName } from '../lib/csrf';
const user = Astro.locals.user;
if (user) return Astro.redirect('/account');
const csrf = Astro.cookies.get('cc_csrf')?.value ?? '';
---
<Base
  title="Create an account — The Cube Chronicles"
  description="Create a free account to ask and answer questions in the Cube Chronicles reader community. Reading the site never requires an account."
  canonicalPath="/register"
  noindex={true}
>
  <div class="container-narrow section">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Create an account' }]} />
    <h1>Create an account</h1>
    <p class="lede">You only need an account to take part in discussions — reading is always open. We'll email you a link to confirm your address.</p>
    <Flash />
    <form method="POST" action="/api/register" class="panel stack">
      <input type="hidden" name={csrfFieldName()} value={csrf} />
      <div class="field">
        <label for="displayName">Display name</label>
        <input id="displayName" name="displayName" type="text" required minlength="2" maxlength="40" autocomplete="nickname" />
        <p class="hint">Shown publicly next to your posts. Not your real name unless you want it to be.</p>
      </div>
      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required maxlength="254" autocomplete="email" />
        <p class="hint">Never shown publicly. Used to confirm your account and send discussion updates you ask for.</p>
      </div>
      <div class="field">
        <label for="password">Password</label>
        <input id="password" name="password" type="password" required minlength="10" maxlength="200" autocomplete="new-password" />
        <p class="hint">At least 10 characters, including a letter and a number.</p>
      </div>
      <div class="field checkbox-field">
        <label class="checkbox"><input type="checkbox" name="notify" value="1" checked /> Email me when there are new approved answers to discussions I join.</label>
      </div>
      <div class="field checkbox-field">
        <label class="checkbox"><input type="checkbox" name="consent" value="1" required /> I agree to receive required account and discussion emails, and I accept the <a href="/terms">Terms</a> and <a href="/privacy">Privacy Policy</a>.</label>
      </div>
      <Turnstile />
      <button class="btn btn-primary btn-block" type="submit">Create account</button>
    </form>
    <p class="muted center signin-link">Already have an account? <a href="/login">Sign in</a>.</p>
  </div>
</Base>

<style>
  .lede { font-size: 1.1rem; }
  .checkbox { display: flex; gap: 0.6rem; align-items: flex-start; font-weight: 500; font-size: 0.95rem; }
  .checkbox input { width: auto; margin-top: 0.2rem; }
  .signin-link { margin-top: 1.25rem; }
</style>
